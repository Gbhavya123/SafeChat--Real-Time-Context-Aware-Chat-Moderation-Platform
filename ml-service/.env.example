# SafeChat ML Service — Environment Variables
# Copy this file to .env and modify as needed.

# Device: "cuda" (GPU) or "cpu"
SAFECHAT_DEVICE=cuda

# Debug mode (enables auto-reload)
SAFECHAT_DEBUG=true

# Server
SAFECHAT_HOST=0.0.0.0
SAFECHAT_PORT=8000

# MongoDB (for feedback storage)
SAFECHAT_MONGODB_URL=mongodb://localhost:27017
SAFECHAT_MONGODB_DB=safechat

# Detoxification mode
# Set to true to use model-based detox (requires more VRAM)
# Set to false for template-based detox (faster, less VRAM)
SAFECHAT_USE_MODEL_DETOX=false

# Ensemble weights for Indian languages
SAFECHAT_WEIGHT_MULTI_INDIAN=0.7
SAFECHAT_WEIGHT_EN_INDIAN=0.3

# Ensemble weights for English/Other
SAFECHAT_WEIGHT_MULTI_OTHER=0.35
SAFECHAT_WEIGHT_EN_OTHER=0.65

# Continuous learning
SAFECHAT_FEEDBACK_THRESHOLD_FOR_RETRAIN=500
SAFECHAT_MODEL_CHECKPOINT_DIR=./checkpoints
